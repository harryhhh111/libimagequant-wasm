{
  "name": "libimagequant-wasm",
  "version": "0.3.0",
  "description": "WASM bindings for libimagequant image quantization library with Web Worker support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.mjs",
      "require": "./dist/worker.cjs",
      "default": "./dist/worker.mjs"
    },
    "./wasm/libimagequant_wasm.js": {
      "types": "./dist/wasm/libimagequant_wasm.d.ts",
      "default": "./dist/wasm/libimagequant_wasm.js"
    },
    "./wasm/libimagequant_wasm_bg.wasm": "./dist/wasm/libimagequant_wasm_bg.wasm"
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm run clean && vite build && pnpm run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:wasm": "wasm-pack build --target web --out-dir dist/wasm",
    "clean": "rm -rf dist/ target/",
    "preview": "vite dev",
    "serve": "vite dev --port 8080",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:manual": "pnpm run build && pnpm run serve",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "image",
    "quantization",
    "palette",
    "png",
    "gif",
    "optimization",
    "compression",
    "color-reduction",
    "web-worker"
  ],
  "author": "Akshet Pandey <argetlam.akshet@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "playwright": "^1.59.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akshetpandey/libimagequant-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/akshetpandey/libimagequant-wasm/issues"
  },
  "homepage": "https://github.com/akshetpandey/libimagequant-wasm#readme",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
